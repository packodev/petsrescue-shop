# Postgres — pooled URL for runtime queries (Neon: hostname includes -pooler)
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Postgres — direct URL for migrations (Neon: hostname without -pooler)
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require"

JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"
ADMIN_EMAIL="admin@petsrescue.shop"
ADMIN_PASSWORD="admin123"

# Stripe — TEST mode keys; swap for live keys in production
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Resend — transactional email
RESEND_API_KEY=""
FROM_EMAIL="noreply@thepawsrescuecenter.com"
ADMIN_NOTIFY_EMAIL="you@example.com"
